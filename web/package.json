{
  "name": "@helsenorge/skjemabygger",
  "private": true,
  "displayName": "skjemabygger",
  "version": "0.0.0",
  "type": "module",
  "maintainers": [
    "VAK"
  ],
  "scripts": {
    "start": "npx vite dev --port 3000",
    "build": "tsc && npx vite build",
    "stylelint": "stylelint src/**/*.{scss,module.scss}",
    "stylelint:fix": "npm run stylelint -- --fix",
    "prepare": "cd .. && husky web/.husky",
    "prebuild": "tsc -b",
    "eslint": "eslint",
    "eslint:fix": "npm run eslint -- --fix",
    "prettier": "prettier --check src/**/*.{js,jsx,ts,tsx,css,scss,md,json}",
    "generate:cssdefinitions": "typed-scss-modules src/**/*.module.scss --implementation sass --nameFormat none --exportType default --includePaths node_modules",
    "prettier:fix": "npm run prettier -- --write",
    "preview": "vite preview",
    "test:run": "vitest",
    "test": "vitest --coverage"
  },
  "dependencies": {
    "@helsenorge/autosuggest": "^38.0.0",
    "@helsenorge/core-build": "^38.0.0",
    "@helsenorge/core-utils": "^38.0.0",
    "@helsenorge/datepicker": "^14.0.0",
    "@helsenorge/designsystem-react": "^14.0.0",
    "@helsenorge/file-upload": "^38.0.0",
    "@helsenorge/refero": "24.1.2",
    "@lexical/code": "^0.35.0",
    "@lexical/hashtag": "^0.35.0",
    "@lexical/link": "^0.35.0",
    "@lexical/list": "^0.35.0",
    "@lexical/mark": "^0.35.0",
    "@lexical/markdown": "^0.35.0",
    "@lexical/overflow": "^0.35.0",
    "@lexical/react": "^0.35.0",
    "@lexical/rich-text": "^0.35.0",
    "@lexical/selection": "^0.35.0",
    "@lexical/table": "^0.35.0",
    "@lexical/utils": "^0.35.0",
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@reduxjs/toolkit": "^2.0.0",
    "classnames": "^2.5.1",
    "crypto-js": "^4.1.1",
    "dompurify": "3.3.2",
    "i18next": "^25.0.0",
    "idb": "^8.0.0",
    "immer": "^11.0.0",
    "lexical": "^0.35.0",
    "papaparse": "^5.4.1",
    "react": "^19.0.0",
    "react-aria-components": "^1.14.0",
    "react-datepicker": "^9.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.0.0",
    "react-redux": "^9.0.0",
    "react-router": "^7.0.0",
    "react-virtualized": "^9.22.5",
    "vite-plugin-svgr": "^4.2.0",
    "vite-tsconfig-paths": "^6.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/fhir": "^0.0.41",
    "@types/node": "^24.0.0",
    "@types/papaparse": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-legacy": "^7.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": ">=9.39.3 <10",
    "eslint-plugin-react-refresh": "^0.4.3",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "sass": "^1.83.4",
    "typescript": "^5.9.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix",
    "*.{css,scss}": "stylelint --fix",
    "*.{js,jsx,ts,tsx,css,scss,md,json}": "prettier --write"
  }
}
